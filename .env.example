# MongoDB
# Feature 004's Excel Import Apply operation is transactional, so the demo database
# must be a replica set (the documented single-node setup uses replica set `rs0`).
MONGODB_URI=mongodb://127.0.0.1:27017/helpdesk?replicaSet=rs0

# Server
PORT=3000

# App mode: development | test | demo
# demo enables the test-support ticket state-transition endpoint (contracts/api.md)
APP_MODE=development

# LLM gateway (single provider abstraction — backend/src/services/llm/)
# Provider: ollama | openai_compat | mock
LLM_PROVIDER=ollama
LLM_MODEL=llama3.1:8b
OLLAMA_URL=http://127.0.0.1:11434
LLM_TIMEOUT_MS=10000

# LM Studio (via openai_compat provider — LM Studio serves an OpenAI-compatible API)
# 1. LM Studio → Developer tab → Start Server (default port 1234)
# 2. Load the model, then set:
# LLM_PROVIDER=openai_compat
# LLM_BASE_URL=http://127.0.0.1:1234/v1
# LLM_API_KEY=lm-studio          # any non-empty value; LM Studio ignores it but the provider requires one
# LLM_MODEL=qwen2.5-7b-instruct  # must match the model id shown in LM Studio's server page

# Optional local embeddings (not yet consumed by the application). Keep this
# separate from LLM_MODEL: LM Studio's embedding model is for future semantic
# retrieval, not chat classification or guided-reply generation.
# EMBEDDING_PROVIDER=openai_compat
# EMBEDDING_BASE_URL=http://127.0.0.1:1234/v1
# EMBEDDING_API_KEY=lm-studio
# EMBEDDING_MODEL=text-embedding-nomic-embed-text-v1.5

# Classification policy
CONFIDENCE_THRESHOLD=0.7
MAX_CLARIFICATION_ROUNDS=2

# Session handling
SESSION_INACTIVITY_MINUTES=30

# Speech-to-text gateway (single provider abstraction — backend/src/services/stt/)
# Ordered, comma-separated chain. Reference config: local only.
# Providers: local (sherpa-onnx Parakeet TDT, in-process) | openai_compat (any /v1/audio/transcriptions server)
STT_PROVIDERS=local
STT_MODEL_DIR=./models/stt
# Reference model: NVIDIA Parakeet TDT 0.6B v2, int8 ONNX export, sherpa-onnx bundle.
# Download and extract into backend/models/stt/ (gitignored, not committed):
# https://github.com/k2-fsa/sherpa-onnx/releases (search "parakeet-tdt-0.6b-v2" asset)

# openai_compat STT fallback (e.g. a local whisper.cpp server or speaches instance)
# STT_OPENAI_BASE_URL=http://127.0.0.1:8000
# STT_OPENAI_API_KEY=

# Recording duration cap (seconds); frontend VITE_VOICE_MAX_SECONDS should match
VOICE_MAX_SECONDS=120

# Frontend (Vite, exposed to client bundle — prefix required)
VITE_VOICE_MAX_SECONDS=120

# Maintainer management API (backend/src/api/routes/admin.ts)
# Guards /api/admin/* (category + guide CRUD). Routes are not mounted at all
# when this is unset. Required per-request header: x-maintainer-key.
MAINTAINER_KEY=
